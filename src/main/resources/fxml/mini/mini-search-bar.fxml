<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import org.controlsfx.control.textfield.CustomTextField?>
<HBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      spacing="10"
      styleClass="mp-search-bar-container"
      fx:id="miniSearchBar"
      fx:controller="io.playqd.mini.controller.MiniSearchBarController">

    <fx:define>
        <HBox fx:id="searchInputLeftNode" spacing="5" alignment="CENTER_LEFT" mouseTransparent="true">
            <padding>
                <Insets left="5"/>
            </padding>
            <FontAwesomeIconView glyphName="SEARCH"/>
        </HBox>
    </fx:define>

    <CustomTextField fx:id="searchInputTextFld"
                     focusTraversable="false"
                     prefHeight="30"
                     promptText="Search library"
                     HBox.hgrow="ALWAYS"
                     left="$searchInputLeftNode"/>

</HBox>