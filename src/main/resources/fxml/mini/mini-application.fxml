<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      prefWidth="550"
      prefHeight="750"
      fx:id="miniApplicationVBox"
      fx:controller="io.playqd.mini.controller.MiniApplicationController">

    <padding>
        <Insets topRightBottomLeft="5"/>
    </padding>

    <fx:include source="mini-search-bar.fxml" fx:id="miniSearchBar"/>

    <fx:include source="mini-player-view.fxml" fx:id="miniPlayerView"/>

    <fx:include source="mini-library-items-view.fxml" fx:id="miniLibraryItemsView"/>

</VBox>