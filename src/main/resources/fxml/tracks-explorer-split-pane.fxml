<?xml version="1.0" encoding="UTF-8"?>

<?import io.playqd.controller.view.TracksView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.MenuItem?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<SplitPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:id="tracksExplorerSplitPane"
           fx:controller="io.playqd.controller.trackexplorer.TracksExplorerViewController"
           dividerPositions="0.15">


    <VBox VBox.vgrow="ALWAYS">

        <ToolBar>
            <MenuButton text="Tracks explorer" style="-fx-background-color: transparent;">
                <items>
                    <MenuItem text="Refresh" onAction="#refresh">
                        <graphic>
                            <FontAwesomeIconView glyphName="REFRESH" glyphSize="10"/>
                        </graphic>
                    </MenuItem>
                </items>
            </MenuButton>
        </ToolBar>

        <ListView fx:id="listView" VBox.vgrow="ALWAYS"/>

        <HBox>
            <padding>
                <Insets right="20"/>
            </padding>
            <Pane HBox.hgrow="ALWAYS"/>

        </HBox>

    </VBox>

    <TracksView fx:id="tracksView"/>

</SplitPane>
