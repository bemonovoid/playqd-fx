<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/24"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="applicationVBox"
      fx:controller="io.playqd.controller.ApplicationController">

    <fx:include source="application-menu-bar.fxml" fx:id="applicationMenuBar"/>

    <VBox VBox.vgrow="ALWAYS">
        <ToolBar>
            <fx:define>
                <ToggleGroup fx:id="viewToggleGroup"/>
            </fx:define>
            <ToggleButton fx:id="libraryViewButton" text="Music" toggleGroup="$viewToggleGroup">
                <graphic>
                    <FontAwesomeIconView glyphName="MUSIC"/>
                </graphic>
            </ToggleButton>
            <ToggleButton fx:id="tracksViewButton" text="Tracks" toggleGroup="$viewToggleGroup">
                <graphic>
                    <FontAwesomeIconView glyphName="FILE_AUDIO_ALT"/>
                </graphic>
            </ToggleButton>
            <ToggleButton fx:id="playlistsViewBtn" text="Playlists" toggleGroup="$viewToggleGroup">
                <graphic>
                    <FontAwesomeIconView glyphName="HEADPHONES"/>
                </graphic>
            </ToggleButton>
            <ToggleButton fx:id="collectionsViewBtn" text="Collections" toggleGroup="$viewToggleGroup">
                <graphic>
                    <FontAwesomeIconView glyphName="CLONE"/>
                </graphic>
            </ToggleButton>
            <ToggleButton fx:id="foldersViewButton" text="Folders" toggleGroup="$viewToggleGroup">
                <graphic>
                    <FontAwesomeIconView glyphName="FOLDER_ALT"/>
                </graphic>
            </ToggleButton>
        </ToolBar>

        <SplitPane fx:id="rootSplitPane" dividerPositions="0.85" VBox.vgrow="ALWAYS">
            <fx:define>
                <fx:include source="music-split-pane.fxml" fx:id="musicSplitPane"/>
                <fx:include source="tracks-explorer-split-pane.fxml" fx:id="tracksExplorerSplitPane"/>
                <fx:include source="playlists-split-pane.fxml" fx:id="playlistsSplitPane"/>
                <fx:include source="collections-split-pane.fxml" fx:id="collectionsSplitPane"/>
                <fx:include source="folders-split-pane.fxml" fx:id="foldersSplitPane"/>
            </fx:define>
            <fx:include source="player-queue.fxml" fx:id="playerQueue"/>
        </SplitPane>

        <fx:include source="player-toolbar.fxml" fx:id="playerToolbar"/>

    </VBox>

</VBox>